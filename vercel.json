{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "staticfiles", "buildCommand": "npm run vercel-build" } }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api/index.py" }
  ]
}
